function buildSection(sectionId){

    const container = document.getElementById(sectionId);
    const section = data[sectionId];

    for(const heading in section){

        const h = document.createElement("h3");
        h.textContent = heading;
        container.appendChild(h);

        section[heading].forEach(text => {

            const div = document.createElement("div");
            div.className = "item";

            div.innerHTML =
                '<input type="checkbox" class="tick">' +
                '<span>' + text + '</span>';

            container.appendChild(div);

        });
    }
}

Object.keys(data).forEach(buildSection);

function calculate(){

    const boxes = document.querySelectorAll(".tick");
    const checked = document.querySelectorAll(".tick:checked");

    const score = boxes.length
        ? Math.round((checked.length / boxes.length) * 100)
        : 0;

    document.getElementById("score").textContent = score + "%";
}

function resetForm(){

    document.querySelectorAll("input").forEach(input => {

        if(input.type === "checkbox"){
            input.checked = false;
        }else{
            input.value = "";
        }

    });

    document.querySelectorAll("textarea").forEach(area => {
        area.value = "";
    });

    document.getElementById("score").textContent = "0%";
}

document.addEventListener("change", calculate);
